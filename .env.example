# ================================================================
# IA-RESTAURANT — Variables de entorno
# Local: copia como .env
# Vercel: Project Settings → Environment Variables
# ================================================================

# --- SUPABASE (obligatorio en producción) ---
# Dashboard → Settings → API
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# --- URL pública (Vercel) ---
# Ejemplo: https://ia-restaurant.vercel.app
VITE_APP_URL=https://tu-app.vercel.app

# --- Opcional ---
VITE_APP_NAME=IA-Restaurant
VITE_APP_VERSION=1.0.0

# --- Admin (solo local, NUNCA en Vercel ni GitHub) ---
# Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=
# Account → Access Tokens → https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
