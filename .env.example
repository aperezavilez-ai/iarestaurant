# ================================================================
# IA-RESTAURANT — Variables de entorno
# Local: copia como .env
# Vercel: Project Settings → Environment Variables
# ================================================================

# --- SUPABASE (obligatorio en producción) ---
# Dashboard → Settings → API
# ⚠️ NO uses el dominio de la app aquí — debe ser *.supabase.co
VITE_SUPABASE_URL=https://pssycnwgolxiwoyzdsdg.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# --- URL pública de la app (dominio Vercel) ---
# ⚠️ NO confundir con VITE_SUPABASE_URL
VITE_APP_URL=https://www.iarestaurant.mx

# --- Opcional ---
VITE_APP_NAME=IA-Restaurant
VITE_APP_VERSION=1.0.0

# --- Admin (solo local, NUNCA en Vercel ni GitHub) ---
# Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=
# Account → Access Tokens → https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# --- Stripe SaaS (plan IA·RESTAURANT — dueño paga a la plataforma) ---
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=
# Webhook endpoint: https://www.iarestaurant.mx/api/stripe/webhook
# Eventos: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=
# Nombres en Stripe Dashboard (Product catalog):
#   "IA·RESTAURANT — Plan Arranque"     mensual $699  · anual $7,339
#   "IA·RESTAURANT — Plan Comando"      mensual $999  · anual $10,489
STRIPE_PRICE_BASICO_MENSUAL=
STRIPE_PRICE_BASICO_ANUAL=
STRIPE_PRICE_PROFESIONAL_MENSUAL=
STRIPE_PRICE_PROFESIONAL_ANUAL=

# --- Resend (correos transaccionales) ---
# resend.com → API Keys + verificar dominio (ej. iarestaurant.mx)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@iarestaurant.mx
RESEND_FROM_NAME=IA·RESTAURANT
